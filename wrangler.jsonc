{
  "name": "cologne",
  "compatibility_date": "2025-06-05",
  "compatibility_flags": ["nodejs_compat"],
  "main": "workers-site/index.js",

  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "404-page"
  },

  "build": {
    "command": "npm run build"
  },

  "dev": {
    "port": 8787,
    "local_protocol": "http"
  },

  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1
    }
  }
}
